{
  "name": "nft-marketplace",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build -w @nft/sdk && npm run build -w @nft/api && npm run build -w @nft/indexer && npm run build -w web",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w @nft/api",
    "dev:indexer": "npm run dev -w @nft/indexer",
    "anchor:build": "anchor build --no-idl --skip-lint",
    "lint": "prettier \"**/*.{ts,tsx,js,json}\" --check",
    "lint:fix": "prettier \"**/*.{ts,tsx,js,json}\" -w"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.28.0"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^3.5.3",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0"
  }
}
